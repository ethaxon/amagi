				},
				"redirect_url": {
					"type": ["string", "null"],
					"default": null
				},
				"device_poll_interval": {
					"type": ["string", "null"],
					"default": null
				},
				"unsafe_frontend_client_secret": {
					"anyOf": [
						{
							"$ref": "#/$defs/UnsafeFrontendClientSecret"
						},
						{
