		"MokaPendingOauthStoreConfig": {
			"description": "Configuration for PendingOauthStore.",
			"type": "object",
			"properties": {
				"ttl": {
					"description": "Time-to-live for pending OAuth entries.",
					"type": "string",
					"default": "5m"
				},
				"max_capacity": {
					"description": "Maximum number of entries in the cache.",
					"type": "integer",
					"format": "uint64",
					"minimum": 0,
					"default": 1000
				}
			}
		},
		"RefreshMaterialProtection": {
			"description": "How refresh tokens are stored / transmitted between server and client.\n\n`Sealed` carries the `master_key` instead of scattering it as a sibling\nfield — the type system guarantees the key is present when sealing is\nenabled.",
			"oneOf": [
				{
					"description": "Refresh tokens are passed through without server-side sealing.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "passthrough"
						}
					},
					"required": ["kind"]
				},
				{
					"description": "Refresh tokens are sealed (AEAD-encrypted) by the server.",
					"type": "object",
					"properties": {
						"master_key": {
							"description": "The AEAD master key used for sealing and unsealing.",
							"$ref": "#/$defs/SecretString"
						},
						"kind": {
							"type": "string",
							"const": "sealed"
						}
					},
					"required": ["kind", "master_key"]
				}
			]
		},
		"MetadataDelivery": {
			"description": "How auth-state metadata (principal, source) is delivered to the client.\n\n`Redemption` carries the store configuration, eliminating the need for a\nseparate config field.",
			"oneOf": [
				{
					"description": "No server-side metadata delivery — the client extracts what it needs\nfrom the token set itself.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "none"
						}
					},
					"required": ["kind"]
				},
				{
					"description": "Metadata is stored server-side and redeemed by the client via a\none-time redemption id included in the callback/refresh fragment.",
					"type": "object",
					"properties": {
						"ttl": {
							"type": "string",
							"default": "1m"
						},
						"max_capacity": {
							"type": "integer",
							"format": "uint64",
							"minimum": 0,
							"default": 1000
						},
						"kind": {
							"type": "string",
							"const": "redemption"
						}
					},
					"required": ["kind"]
				}
			]
		},
		"PostAuthRedirectPolicy": {
			"description": "Who validates the `post_auth_redirect_uri` after callback / refresh.\n\n`Resolved` carries the redirect policy configuration, ensuring the\nallowlist config is always present when the resolved policy is selected.",
			"oneOf": [
				{
					"description": "The caller (route / app glue) is responsible for supplying and\nvalidating the redirect URI. The service applies no policy.",
					"type": "object",
					"properties": {
						"kind": {
							"type": "string",
							"const": "caller_validated"
						}
					},
					"required": ["kind"]
				},
				{
					"description": "The service resolves and validates the redirect URI against an\nallowlist / policy configuration owned by the runtime.",
					"type": "object",
					"properties": {
						"default_redirect_target": {
							"type": ["string", "null"],
							"default": null
						},
						"dynamic_redirect_target_enabled": {
							"type": "boolean",
							"default": false
						},
						"allowed_redirect_targets": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/RedirectTargetRule"
							},
							"default": []
						},
						"kind": {
							"type": "string",
							"const": "resolved"
						}
					},
					"required": ["kind"]
				}
			]
		},
		"RedirectTargetRule": {
			"oneOf": [
				{
					"type": "object",
					"properties": {
						"type": {
							"type": "string",
							"const": "regex"
						},
						"value": {
							"type": "object",
							"properties": {
								"value": {
									"type": "string"
								}
							},
							"required": ["value"]
						}
					},
					"required": ["type", "value"]
				},
				{
					"type": "object",
					"properties": {
						"type": {
							"type": "string",
							"const": "all"
						}
					},
					"required": ["type"]
				},
				{
					"type": "object",
					"properties": {
						"type": {
							"type": "string",
							"const": "strict"
						},
						"value": {
							"type": "object",
							"properties": {
								"value": {
									"type": "string"
								}
							},
							"required": ["value"]
						}
					},
					"required": ["type", "value"]
				}
			]
		},
