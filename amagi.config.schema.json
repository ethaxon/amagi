{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "ApiServerConfigInput",
	"type": "object",
	"properties": {
		"server": {
			"$ref": "#/$defs/ServerConfig",
			"default": {
				"host": "127.0.0.1",
				"port": 7800
			}
		},
		"external_base_url": {
			"type": ["string", "null"],
			"default": null
		},
		"default_oidc_source": {
			"type": ["string", "null"],
			"default": null
		},
		"oidc_sources": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/$defs/OidcSourceConfig"
			}
		},
		"token_set": {
			"$ref": "#/$defs/TokenSetConfig",
			"default": {
				"facade_paths": {
					"start": "/api/auth/token-set/oidc/source/{source}/start",
					"callback": "/api/auth/token-set/oidc/source/{source}/callback"
				},
				"storage_policy": {
					"pending_state_store": "server-moka",
					"refresh_token_material": "sealed"
				},
				"browser_client_binding_required": true,
				"cookie_session_dashboard_only": true
			}
		},
		"database": {
			"$ref": "#/$defs/DatabaseConfig",
			"default": {
				"url": null,
				"auto_migrate": false
			}
		}
	},
	"additionalProperties": false,
	"$defs": {
		"ServerConfig": {
			"type": "object",
			"properties": {
				"host": {
					"type": "string",
					"default": "127.0.0.1"
				},
				"port": {
					"type": "integer",
					"format": "uint16",
					"minimum": 0,
					"maximum": 65535,
					"default": 7800
				}
			},
			"additionalProperties": false
		},
		"OidcSourceConfig": {
			"type": "object",
			"properties": {
				"oidc": {
					"$ref": "#/$defs/TokenSetOidcSharedIntersectionConfig"
				},
				"backend_oidc": {
					"$ref": "#/$defs/BackendOidcModeOverrideConfig"
				},
				"frontend_oidc": {
					"$ref": "#/$defs/FrontendOidcModeOverrideConfig"
				},
				"access_token_substrate": {
					"$ref": "#/$defs/AccessTokenSubstrateConfig"
				},
				"oidc_identity_claim": {
					"$ref": "#/$defs/OidcIdentityClaimConfig",
					"default": {
						"type": "sub"
					}
				}
			},
			"additionalProperties": false
		},
		"TokenSetOidcSharedIntersectionConfig": {
			"description": "Shared provider connectivity settings used by both OIDC clients and\nresource-server verifiers.",
			"type": "object",
			"properties": {
				"client_id": {
					"type": ["string", "null"],
					"default": ""
				},
				"client_secret": {
					"anyOf": [
						{
							"$ref": "#/$defs/SecretString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"well_known_url": {
					"description": "OpenID Connect discovery document URL.\n\nWhen set, the runtime fetches remote metadata and periodically refreshes\nit when `metadata_refresh_interval > 0`.",
					"type": ["string", "null"],
					"default": ""
				},
				"issuer_url": {
					"type": ["string", "null"],
					"default": ""
				},
				"jwks_uri": {
					"type": ["string", "null"],
					"default": ""
				},
				"metadata_refresh_interval": {
					"description": "Refresh interval for the discovery metadata cache.\n\nSet to `0` to disable periodic discovery refresh.",
					"type": "string",
					"default": "0s"
				},
				"jwks_refresh_interval": {
					"description": "Refresh interval for the remote JWKS cache.\n\nSet to `0` to disable time-based JWKS refresh.",
					"type": "string",
					"default": "5m"
				},
				"authorization_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"token_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"userinfo_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"introspection_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"revocation_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"device_authorization_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"token_endpoint_auth_methods_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"id_token_signing_alg_values_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"userinfo_signing_alg_values_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"scopes": {
					"$ref": "#/$defs/StringOrVecString",
					"default": "\"openid\" \"profile\" \"email\""
				},
				"required_scopes": {
					"$ref": "#/$defs/StringOrVecString",
					"default": ""
				},
				"claims_check_script": {
					"type": ["string", "null"],
					"default": null
				},
				"pkce_enabled": {
					"type": "boolean",
					"default": false
				},
				"redirect_url": {
					"type": ["string", "null"],
					"default": null
				},
				"device_poll_interval": {
					"type": "string",
					"default": "5s"
				}
			}
		},
		"SecretString": {
			"description": "Secret-bearing string wrapper that redacts debug/serialization output.",
			"type": "string",
			"format": "password",
			"writeOnly": true
		},
		"StringOrVecString": {
			"anyOf": [
				{
					"type": "string"
				},
				{
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			]
		},
		"BackendOidcModeOverrideConfig": {
			"type": "object",
			"properties": {
				"client_id": {
					"type": ["string", "null"],
					"default": ""
				},
				"client_secret": {
					"anyOf": [
						{
							"$ref": "#/$defs/SecretString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"well_known_url": {
					"type": ["string", "null"],
					"default": ""
				},
				"issuer_url": {
					"type": ["string", "null"],
					"default": ""
				},
				"jwks_uri": {
					"type": ["string", "null"],
					"default": ""
				},
				"metadata_refresh_interval": {
					"type": ["string", "null"],
					"default": null
				},
				"jwks_refresh_interval": {
					"type": ["string", "null"],
					"default": null
				},
				"authorization_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"token_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"userinfo_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"introspection_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"revocation_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"device_authorization_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"token_endpoint_auth_methods_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"id_token_signing_alg_values_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"userinfo_signing_alg_values_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"scopes": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"required_scopes": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"claims_check_script": {
					"type": ["string", "null"],
					"default": null
				},
				"pkce_enabled": {
					"type": ["boolean", "null"],
					"default": null
				},
				"redirect_url": {
					"type": ["string", "null"],
					"default": null
				},
				"device_poll_interval": {
					"type": ["string", "null"],
					"default": null
				},
				"pending_store": {
					"anyOf": [
						{
							"$ref": "#/$defs/MokaPendingOauthStoreConfig"
						},
						{
							"type": "null"
						}
					]
				},
				"refresh_material_protection": {
					"anyOf": [
						{
							"$ref": "#/$defs/RefreshMaterialProtection"
						},
						{
							"type": "null"
						}
					]
				},
				"metadata_delivery": {
					"anyOf": [
						{
							"$ref": "#/$defs/MetadataDelivery"
						},
						{
							"type": "null"
						}
					]
				},
				"post_auth_redirect": {
					"anyOf": [
						{
							"$ref": "#/$defs/PostAuthRedirectPolicy"
						},
						{
							"type": "null"
						}
					]
				}
			}
