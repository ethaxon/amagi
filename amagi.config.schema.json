					"type": ["string", "null"],
					"default": ""
				},
				"metadata_refresh_interval": {
					"type": ["string", "null"],
					"default": null
				},
				"jwks_refresh_interval": {
					"type": ["string", "null"],
					"default": null
				},
				"authorization_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"token_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"userinfo_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"introspection_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"revocation_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"device_authorization_endpoint": {
					"type": ["string", "null"],
					"default": ""
				},
				"token_endpoint_auth_methods_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"id_token_signing_alg_values_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"userinfo_signing_alg_values_supported": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"scopes": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"required_scopes": {
					"anyOf": [
						{
							"$ref": "#/$defs/StringOrVecString"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"claims_check_script": {
					"type": ["string", "null"],
					"default": null
				},
				"pkce_enabled": {
					"type": ["boolean", "null"],
