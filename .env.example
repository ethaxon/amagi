# Prefer the committed local demo config for the Iter12 happy path.
AMAGI_CONFIG_FILE=dev/amagi.config.local.toml

# Simple bind and base URL overrides fit well in env.
AMAGI_SERVER__PORT=7800
AMAGI_EXTERNAL_BASE_URL=http://127.0.0.1:7800

# Secrets and local infrastructure URLs may also come from env.
AMAGI_DATABASE__URL=postgres://amagi:amagi@localhost:5432/amagi
# Keep this false by default; true is for local development smoke tests only.
AMAGI_DATABASE__AUTO_MIGRATE=false
AMAGI_DEFAULT_OIDC_SOURCE=default
AMAGI_OIDC_SOURCES__default__OIDC__CLIENT_SECRET=replace-me
# Default binding claim is `sub`; uncomment to use a non-default account binding policy.
# AMAGI_OIDC_SOURCES__workforce__OIDC_IDENTITY_CLAIM__TYPE=email
# AMAGI_OIDC_SOURCES__workforce__OIDC_IDENTITY_CLAIM__TYPE=custom_claim
# AMAGI_OIDC_SOURCES__workforce__OIDC_IDENTITY_CLAIM__CLAIM_NAME=employee_id